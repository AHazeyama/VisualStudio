<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brushes -->
<!--    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F5F5"/> -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#C0FFFF"/>
    <SolidColorBrush x:Key="ButtonTextBrush" Color="White"/>
    <SolidColorBrush x:Key="ButtonTextDarkBrush" Color="#222222"/>

    <!-- Base Button -->
    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="BorderBrush" Value="#777777"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Scan : Cyan -->
    <Style x:Key="ScanButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
<!--
                    <GradientStop Color="#35DFFF" Offset="0"/>
                    <GradientStop Color="#00A6D6" Offset="1"/>
-->
                    <GradientStop Color="#CCFFFF" Offset="0"/>
                    <GradientStop Color="#00ABD0" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Execute : Delete / Rename : Red -->
    <Style x:Key="ExecuteButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
<!--
                    <GradientStop Color="#FF6B6B" Offset="0"/>
                    <GradientStop Color="#D00000" Offset="1"/>
-->
                    <GradientStop Color="#FFCCFF" Offset="0"/>
                    <GradientStop Color="#FF0066" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Undo : Yellow -->
    <Style x:Key="UndoButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Foreground" Value="#222222"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
<!--
                    <GradientStop Color="#FFF176" Offset="0"/>
                    <GradientStop Color="#FBC02D" Offset="1"/>

                    <GradientStop Color="#FFFFCC" Offset="0"/>
-->
                    <GradientStop Color="#FFFFCC" Offset="0"/>
                    <GradientStop Color="#FBC02D" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Exit : Black -->
    <Style x:Key="ExitButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
<!--				
                    <GradientStop Color="#444444" Offset="0"/>
                    <GradientStop Color="#111111" Offset="1"/>
-->
                    <GradientStop Color="#CCCCCC" Offset="0"/>
                    <GradientStop Color="#111111" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Other : Gray -->
    <Style x:Key="SubButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Foreground" Value="#222222"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
<!--
                    <GradientStop Color="#EEEEEE" Offset="0"/>
                    <GradientStop Color="#BDBDBD" Offset="1"/>
-->
                    <GradientStop Color="#CCCCCC" Offset="0"/>
                    <GradientStop Color="#5F5F5F" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
