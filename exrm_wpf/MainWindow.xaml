    <Window x:Class="ExrmWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exclusive removal tool [exrm]" Height="520" Width="640"
		Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row0: Exec directory -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Exec directory"/>
            <TextBox x:Name="ExecDirTextBox" Grid.Column="1" Margin="6,0,6,0" IsReadOnly="True"/>
            <Button Grid.Column="2" Content="Select" Click="Select_Click"/>
        </Grid>

        <!-- Row1: not removed words + recursive -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="not removed words"/>
            <StackPanel Grid.Column="1">
                <TextBox x:Name="NotRemovedWordsTextBox" Margin="6,0,0,6"
                         ToolTip="カンマ区切りで複数指定できます（空白は無視）"/>
                 <CheckBox x:Name="RecursiveCheckBox" Content="Recursive processing" IsChecked="True"/>
             </StackPanel>
         </Grid>

         <!-- Row2: log -->
         <GroupBox Grid.Row="2" Header="Processing message">
            <RichTextBox x:Name="LogTextBox"
                FontFamily="Meiryo UI"
                FontSize="12"
                Background="#202020"
                Foreground="DeepSkyBlue"
                IsReadOnly="True"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                BorderBrush="#505050"
                BorderThickness="1"
                Padding="8"/>
         </GroupBox>

         <!-- Row3: buttons -->
         <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
             <Button Content="ExRemove" Width="110" Margin="0,0,8,0" Click="ExRemove_Click"/>
             <Button Content="Clear" Width="110" Margin="0,0,8,0" Click="Clear_Click"/>
             <Button Content="Undo" Width="110" Margin="0,0,8,0" Click="Undo_Click"/>
             <Button Content="Help" Width="110" Margin="0,0,8,0" Click="Help_Click"/>
             <Button Content="Exit" Width="110" Click="Exit_Click"/>
         </StackPanel>
     </Grid>
 </Window>
