<Window x:Class="exrm_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exclusive removal tool [exrm]"
        Height="520"
        Width="690"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Exec directory"/>
            <TextBox x:Name="ExecDirTextBox"
                     Margin="111,6,4,10"
                     IsReadOnly="True" TextChanged="ExecDirTextBox_TextChanged" Grid.ColumnSpan="2"/>

            <Button Grid.Column="2"
                    Content="Select"
                    Click="Select_Click"
                    Style="{StaticResource SubButtonStyle}"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="not removed words" RenderTransformOrigin="0.562,0.003" Margin="0,3,0,0" Height="16"/>

            <StackPanel Grid.Column="1">
                <TextBox x:Name="NotRemovedWordsTextBox"
                         ToolTip="残したい文字列を入力します。カンマ・空白・改行区切りで複数指定できます。" Height="20" Width="534" RenderTransformOrigin="0.451,0.577"/>
                <CheckBox x:Name="RecursiveCheckBox"
                          Content="Recursive processing"
                          IsChecked="True" RenderTransformOrigin="0.502,0.996"/>
            </StackPanel>
        </Grid>

        <GroupBox Grid.Row="2" Header="Processing message">
            <RichTextBox x:Name="LogTextBox"
                         FontFamily="Meiryo UI"
                         FontSize="12"
                         Background="#202020"
                         Foreground="DeepSkyBlue"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         BorderBrush="#505050"
                         BorderThickness="1"
                         Padding="8"/>
        </GroupBox>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0">

            <Button Content="Scan"
                    Width="95"
                    Margin="0,0,8,0"
                    Click="Scan_Click"
                    Style="{StaticResource ScanButtonStyle}"/>

            <Button Content="Delete"
                    Width="95"
                    Margin="0,0,8,0"
                    Click="Delete_Click"
                    Style="{StaticResource ExecuteButtonStyle}"/>

            <Button Content="Undo"
                    Width="95"
                    Margin="0,0,8,0"
                    Click="Undo_Click"
                    Style="{StaticResource UndoButtonStyle}"/>

            <Button Content="Clear"
                    Width="95"
                    Margin="0,0,8,0"
                    Click="Clear_Click"
                    Style="{StaticResource SubButtonStyle}"/>

            <Button Content="Help"
                    Width="95"
                    Margin="0,0,8,0"
                    Click="Help_Click"
                    Style="{StaticResource SubButtonStyle}"/>

            <Button Content="Exit"
                    Width="95"
                    Click="Exit_Click"
                    Style="{StaticResource ExitButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>