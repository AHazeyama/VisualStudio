#-----------------------------------------------------------
# Doxygen 設定（Python向け / README.md を Main Page）
#-----------------------------------------------------------

# プロジェクト名（画面上部などに表示）
PROJECT_NAME           = hashgc_tk_VS

# プロジェクト概要（任意）
PROJECT_BRIEF          = "Hash value generation and comparison tool [hashgc]"

# 出力先（docs/html/index.html が生成される）
OUTPUT_DIRECTORY       = docs
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

# UI言語（Doxygenのメニュー表示など）
OUTPUT_LANGUAGE        = Japanese

# 文字コード（日本語コメント/README用）
INPUT_ENCODING         = UTF-8

#-----------------------------------------------------------
# 入力（ここが一番重要）
#-----------------------------------------------------------

# 解析対象：ソース（src）と README を明示
# 例）project/
#      ├─ hashgc_tk.py
#      └─ README.md
INPUT                  = README.md .

# サブディレクトリも含める
RECURSIVE              = YES

# 対象拡張子（Python + Markdown）
FILE_PATTERNS          = *.py *.md

# README.md をメインページとして使用（★これで Main Page が README になる）
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md

# パスを短く（プロジェクトルート基準に整える）
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

#-----------------------------------------------------------
# 抽出（コメントが無くても構造を出す）
#-----------------------------------------------------------

# コメントが無い要素も出す（★Files/Functions/Classesを出すのに重要）
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# Pythonは Doxygen 的に “Java最適化” が安定（★Pythonで構造が出やすくなる）
OPTIMIZE_OUTPUT_JAVA   = YES

# docstring を拾う
PYTHON_DOCSTRING       = YES

#-----------------------------------------------------------
# 表示・ナビ
#-----------------------------------------------------------

# ツリー表示（左側ナビが便利になる）
GENERATE_TREEVIEW      = YES

# ファイル一覧やソースブラウザを有効化
SHOW_FILES             = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# 参照関係を出す（"Referenced by" など）
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#-----------------------------------------------------------
# 図（Graphviz が入っている場合）
#-----------------------------------------------------------

HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg

#-----------------------------------------------------------
# 警告（うるさければ NO に）
#-----------------------------------------------------------

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

#-----------------------------------------------------------
# よくある除外（必要なら追加）
#-----------------------------------------------------------

# 生成物や仮想環境などを除外
EXCLUDE                = hashgc_env build dist docs .git
EXCLUDE_PATTERNS       = hashgc_env/* venv/* __pycache__/* build/* dist/* docs/*

#-----------------------------------------------------------
# 任意：トップにロゴを出したい場合（画像を置いたら指定）
#-----------------------------------------------------------
# PROJECT_LOGO           = assets/logo.png

